---
const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section class="hero bg-gray-50 py-36">
  <div class="container text-center max-w-3xl mx-auto">
    <h1 class="text-5xl md:text-6xl font-bold leading-tight text-gray-900 mb-6">
      {title}
    </h1>

    <p class="text-xl md:text-2xl text-gray-600 mb-10">
      {subtitle}
    </p>

    {ctaText && ctaLink && (
      <a
        href={ctaLink}
        class="inline-block bg-blue-600 text-white font-semibold px-8 py-4 rounded-xl hover:bg-blue-700 transition"
      >
        {ctaText}
      </a>
    )}
  </div>
</section>