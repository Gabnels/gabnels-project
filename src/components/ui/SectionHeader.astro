---
const { title, subtitle = null, center = true } = Astro.props;
---

<div class={center ? "text-center mb-12" : "mb-12"}>
  <h2 class="text-2xl md:text-3xl font-semibold text-brand-secondary">
    {title}
  </h2>

  {subtitle && (
    <p class="mt-3 text-brand-muted max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
