---
const { name, description, photo, href } = Astro.props;
---

<div class="flex flex-col items-center max-w-sm mx-auto text-center">
  <img src={photo} alt={name} class="w-32 h-32 rounded-full mb-4 object-cover" />
  <h3 class="text-xl font-semibold mb-2">{name}</h3>
  <p class="mb-4">{description}</p>
  <a href={href} class="text-blue-600 hover:underline">Sobre mí →</a>
</div>