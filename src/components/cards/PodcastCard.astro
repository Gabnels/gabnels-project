---
import Card from "../ui/Card.astro";
import CardTitle from "../ui/CardTitle.astro";
import CardContent from "../ui/CardContent.astro";
import CardFooter from "../ui/CardFooter.astro";

const { title, description, link, episodeNumber, image } = Astro.props;
---

<Card class="overflow-hidden p-0">

  {image && (
    <img
      src={image}
      alt={title}
      class="w-full h-48 object-cover"
      loading="lazy"
    />
  )}

  <div class="p-6 space-y-3">

    <span class="text-sm text-gray-500">
      Episodio {episodeNumber}
    </span>

    <CardTitle>
      {title}
    </CardTitle>

    <CardContent>
      {description}
    </CardContent>

    <CardFooter>
      <a
        href={link}
        class="text-blue-600 font-medium text-sm hover:underline"
      >
        Escuchar →
      </a>
    </CardFooter>

  </div>

</Card>