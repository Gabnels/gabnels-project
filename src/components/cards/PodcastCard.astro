---
const { title, description, link, episodeNumber } = Astro.props;
---

<article
  class="group p-6 rounded-2xl bg-gray-50 border border-gray-200 space-y-4
         transition-all duration-300
         hover:bg-white hover:shadow-lg hover:-translate-y-1"
>
  <span class="text-sm text-gray-500">
    Episodio {episodeNumber}
  </span>

  <h3
    class="text-xl font-semibold text-gray-900
           group-hover:text-blue-600 transition-colors"
  >
    {title}
  </h3>

  <p class="text-gray-600">
    {description}
  </p>

  <a
    href={link}
    class="font-medium text-blue-600 group-hover:underline"
  >
    Escuchar →
  </a>
</article>