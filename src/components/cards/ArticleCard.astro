---
import Card from "../ui/Card.astro";
import CardTitle from "../ui/CardTitle.astro";
import CardContent from "../ui/CardContent.astro";
import CardFooter from "../ui/CardFooter.astro";

const { title, excerpt, link, category } = Astro.props;
---

<Card class="space-y-4">

  {category && (
    <span class="text-sm uppercase tracking-wide text-gray-500">
      {category}
    </span>
  )}

  <CardTitle>
    {title}
  </CardTitle>

  <CardContent>
    {excerpt}
  </CardContent>

  <CardFooter>
    <a
      href={link}
      class="inline-block font-medium text-blue-600 hover:underline transition"
    >
      Leer más →
    </a>
  </CardFooter>

</Card>