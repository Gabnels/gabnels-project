---
const { title, subtitle, items } = Astro.props;
---

<section>

  <!-- Header -->
  <div class="text-center mb-12">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
      {title}
    </h2>

    <p class="text-gray-600 mt-3 max-w-2xl mx-auto">
      {subtitle}
    </p>
  </div>

  <!-- Podcast Grid -->
  <div class="grid md:grid-cols-3 gap-8">

    {items.map((episode) => (

      <article class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition">

        <!-- Imagen -->
        {episode.image && (
          <img
            src={episode.image}
            alt={episode.title}
            class="w-full h-48 object-cover"
            loading="lazy"
          />
        )}

        <!-- Content -->
        <div class="p-6">

          <span class="text-sm text-gray-500">
            Episodio {episode.episodeNumber}
          </span>

          <h3 class="text-lg font-semibold text-gray-900 mt-2 mb-2">
            {episode.title}
          </h3>

          <p class="text-gray-600 text-sm mb-4">
            {episode.description}
          </p>

          <a
            href={episode.link}
            class="text-blue-600 font-medium text-sm hover:underline"
          >
            Escuchar →
          </a>

        </div>

      </article>

    ))}

  </div>

</section>