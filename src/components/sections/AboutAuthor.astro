---
const { name, description, imageUrl, link } = Astro.props;
---

<section class="max-w-4xl mx-auto grid md:grid-cols-2 gap-10 items-center">

  <!-- Avatar -->
  <div class="flex justify-center md:justify-start">
    <img
      src={imageUrl}
      alt={name}
      class="w-40 h-40 rounded-full object-cover object-[center_30%] shadow-lg border-4 border-white ring-2 ring-gray-200"
      loading="lazy"
    />
  </div>

  <!-- Texto -->
  <div>

    <h2 class="text-3xl font-bold text-gray-900 mb-4">
      Sobre el autor
    </h2>

    <p class="text-gray-600 mb-6 leading-relaxed">
      {description}
    </p>

    <a
      href={link}
      class="inline-flex items-center border border-gray-900 text-gray-900 font-medium px-6 py-3 rounded-lg hover:bg-gray-900 hover:text-white transition"
    >
      Conocer más
    </a>

  </div>

</section>