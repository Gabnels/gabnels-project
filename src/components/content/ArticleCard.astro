---
const { title, excerpt, link, category } = Astro.props;
---

<article
  class="group p-6 border border-gray-200 rounded-2xl bg-white space-y-4
         transition-all duration-300
         hover:-translate-y-1 hover:shadow-lg hover:border-gray-300"
>
  {category && (
    <span
      class="text-sm uppercase tracking-wide text-gray-500
             transition-colors group-hover:text-gray-700"
    >
      {category}
    </span>
  )}

  <h3
    class="text-xl font-semibold text-gray-900
           transition-colors group-hover:text-blue-600"
  >
    {title}
  </h3>

  <p class="text-gray-600 leading-relaxed">
    {excerpt}
  </p>

  <a
    href={link}
    class="inline-block font-medium text-blue-600
           transition-all group-hover:underline group-hover:translate-x-1"
  >
    Leer más →
  </a>
</article>