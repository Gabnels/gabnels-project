---
const { name, description, imageUrl, link } = Astro.props;
---

<section class="about-author bg-gray-50 py-20">
  <div class="container flex flex-col md:flex-row items-center gap-8">
    <img src={imageUrl} alt={name} class="w-48 h-48 rounded-full object-cover" />
    <div>
      <h2 class="text-3xl font-bold mb-4">{name}</h2>
      <p class="text-gray-700 mb-4">{description}</p>
      <a href={link} class="text-blue-600 font-semibold hover:underline">
        Conóceme →
      </a>
    </div>
  </div>
</section>
