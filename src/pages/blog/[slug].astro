---
import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { jsonLd } from "../../lib/seo";
import ProductCTA from "../../components/marketing/ProductCTA.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const allPosts = await getCollection("blog");

const relatedPosts = allPosts
  .filter(p => {
    if (p.id === post.id) return false;

    const hasSameTag = p.data.tags?.some(tag =>
      post.data.tags?.includes(tag)
    );

    const sameCategory = p.data.category === post.data.category;

    return hasSameTag || sameCategory;
  })
  .slice(0, 3);

/* =========================
   Imagen optimizada para OG
   ========================= */

const optimizedImage = await getImage({
  src: post.data.image,
  width: 1200,
  height: 630,
});

/* =========================
   SEO dinámico
   ========================= */

const pageTitle = post.data.title;
const pageDescription = post.data.description;
const pageUrl = `https://tudominio.com/blog/${post.slug}`;
const imageUrl = new URL(optimizedImage.src, Astro.site).href;

/* =========================
   JSON-LD STRUCTURED DATA
   ========================= */

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: pageTitle,
  description: pageDescription,
  image: imageUrl,
  author: {
    "@type": "Person",
    name: "Gabnels"
  },
  datePublished: post.data.date,
  mainEntityOfPage: pageUrl,
  url: pageUrl,
  keywords: post.data.tags?.join(", ")
};
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <Fragment slot="head">

    <link rel="canonical" href={pageUrl} />

    <!-- OpenGraph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- JSON-LD -->
    <Fragment set:html={jsonLd(structuredData)} />

  </Fragment>

  <!-- CONTENIDO -->
  <article class="container py-16 max-w-3xl">

    <!-- Imagen principal -->
    <div class="mb-10">
      <Image
        src={post.data.image}
        alt={post.data.title}
        width={1200}
        height={700}
        class="w-full rounded-2xl object-cover"
      />
    </div>

    <!-- categoría -->
    <p class="text-sm text-gray-500 mb-2 uppercase tracking-wide">
      {post.data.category}
    </p>

    <!-- título -->
    <h1 class="text-4xl font-bold mb-4 leading-tight">
      {post.data.title}
    </h1>

    <!-- TAGS visibles -->
    {post.data.tags && (
      <div class="flex flex-wrap gap-2 mb-6">
        {post.data.tags.map(tag => (
          <a
            href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g,"-")}`}
            class="text-xs bg-gray-100 hover:bg-black hover:text-white px-3 py-1 rounded-full transition"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- descripción -->
    <p class="text-gray-600 mb-10 text-lg">
      {post.data.description}
    </p>

    <!-- contenido -->
     {headings.length > 0 && (
  <nav class="mb-10 p-6 bg-brand-soft rounded-2xl border border-brand-border">
    <p class="text-sm font-semibold mb-4 text-brand-secondary">
      Contenido
    </p>

    <ul class="space-y-2 text-sm">
      {headings.map(h => (
        <li class={h.depth === 3 ? "ml-4 text-xs" : ""}>
          <a 
            href={`#${h.slug}`} 
            class="text-brand-muted hover:text-brand-primary transition"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

    <div class="prose prose-lg max-w-none 
      prose-headings:font-serif
      prose-h2:text-2xl
      prose-h2:mt-12
      prose-h2:mb-4
      prose-h3:text-xl
      prose-h3:mt-8
      prose-h3:mb-3
      prose-p:text-brand-muted
      prose-p:leading-relaxed
      prose-strong:text-brand-secondary
      prose-li:marker:text-brand-primary
    ">
      <Content />
    </div>

    <!-- CTA GLOBAL -->
    <div class="mt-12">
      <ProductCTA category={post.data.category} />
    </div>

    {relatedPosts.length > 0 && (
      <section class="mt-16">
        <h3 class="text-xl font-semibold mb-6">
          Artículos relacionados
        </h3>

        <div class="grid md:grid-cols-3 gap-6">
          {relatedPosts.map(p => (
            <a 
              href={`/blog/${p.slug}`} 
              class="block p-4 border border-brand-border rounded-xl hover:shadow-card transition"
            >
              <p class="text-sm text-brand-muted mb-2">
                {p.data.category}
              </p>

              <h4 class="font-semibold text-brand-secondary">
                {p.data.title}
              </h4>
            </a>
          ))}
        </div>
      </section>
    )}

  </article>

</BaseLayout>