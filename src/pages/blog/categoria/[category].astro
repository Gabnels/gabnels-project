---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SectionHeader from "../../../components/ui/SectionHeader.astro";
import Card from "../../../components/ui/Card.astro";
import Badge from "../../../components/ui/Badge.astro";
import Button from "../../../components/ui/Button.astro";
import CategoriesSidebar from "../../../components/blog/CategoriesSidebar.astro";
import Breadcrumb from "../../../components/ui/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { jsonLd } from "../../../lib/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  const categories = [...new Set(posts.map(p => p.data.category))];

  return categories.map(category => ({
    params: { category: category.toLowerCase() },
    props: { category }
  }));
}

const { category } = Astro.props;

const posts = await getCollection("blog");

// filtrado + orden
const filteredPosts = posts
  .filter(p => p.data.category.toLowerCase() === category)
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date));

// contador categorías
const categoryCount = posts.reduce((acc, post) => {
  const cat = post.data.category;
  acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {});

// JSON-LD SEO dinámico por categoría
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Categoría ${category}`,
  description: `Artículos publicados en la categoría ${category}`,
  url: Astro.url.href
};
---

<BaseLayout
  title={`Categoría: ${category}`}
  description={`Artículos publicados en la categoría ${category}`}
>

<!-- JSON-LD -->
<Fragment set:html={jsonLd(structuredData)} />

<section class="section-soft">
  <div class="container">

    <SectionHeader
      title={`Categoría: ${category}`}
      subtitle="Artículos filtrados automáticamente"
    />

    <div class="mt-4">
      <Breadcrumb
        items={[
          { label: "Inicio", href: "/" },
          { label: "Blog", href: "/blog" },
          { label: category }
        ]}
      />
    </div>

    <div class="grid lg:grid-cols-[250px_1fr] gap-10 mt-10">

      <aside class="order-2 lg:order-1">
        <CategoriesSidebar
          categories={categoryCount}
          activeCategory={category}
        />
      </aside>

      <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8 order-1 lg:order-2">

        {filteredPosts.length === 0 ? (
          <p class="text-gray-500">No hay artículos en esta categoría.</p>
        ) : (
          filteredPosts.map(post => (
            <Card>

              <Badge
                label={`${post.data.category} (${categoryCount[post.data.category]})`}
                href={`/blog/categoria/${post.data.category.toLowerCase()}`}
                active={post.data.category.toLowerCase() === category}
              />

              <h2 class="text-xl font-semibold mt-3">
                {post.data.title}
              </h2>

              <p class="text-gray-600 mt-2">
                {post.data.description}
              </p>

              <div class="mt-5">
                <Button href={`/blog/${post.slug}`}>
                  Leer artículo
                </Button>
              </div>

            </Card>
          ))
        )}

      </div>

    </div>

  </div>
</section>

</BaseLayout>
