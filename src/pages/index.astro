---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import FeaturedArticles from "../components/sections/FeaturedArticles.astro";
import FeaturedPodcast from "../components/sections/FeaturedPodcast.astro";
import AboutAuthor from "../components/sections/AboutAuthor.astro";
import Card from "../components/ui/Card.astro";
import CardIcon from "../components/ui/CardIcon.astro";
import CardTitle from "../components/ui/CardTitle.astro";
import CardContent from "../components/ui/CardContent.astro";
import CardFooter from "../components/ui/CardFooter.astro";
import { getCollection } from "astro:content";
import { TrendingUp, Brain, BookOpen } from "@lucide/astro";

const posts = await getCollection("blog");

const podcastEpisodes = [
{
title: "Mentalidad financiera",
description: "Cómo gestionar tu dinero y crecer tu patrimonio paso a paso.",
link: "/podcast/mentalidad-financiera",
episodeNumber: "12",
image: "/images/podcast/episodio-uno.jpg"
},
{
title: "Pensamiento crítico en la sociedad actual",
description: "Reflexión sobre la información y manipulación en redes.",
link: "/podcast/pensamiento-critico",
episodeNumber: "11",
image: "/images/podcast/episodio-dos.jpg"
},
{
title: "Literatura y creatividad",
description: "Cómo los libros pueden transformar tu forma de pensar.",
link: "/podcast/literatura-creatividad",
episodeNumber: "10",
image: "/images/podcast/episodio-tres.jpg"
}
];
---

<BaseLayout
  title="Inicio"
  description="Blog de Gabnels sobre finanzas, estrategia y pensamiento independiente"
>

  <!-- HERO -->
  <Hero />

  <!-- PILARES -->
<section class="bg-gray-50 py-16">
  <div class="max-w-6xl mx-auto px-6 text-center">

    <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
      De la confusión a la claridad estratégica
    </h2>

    <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
      Tres pilares para dejar de consumir contenido sin avanzar y empezar a construir ingresos reales en internet.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mt-12">

      <!-- ESTRATEGIA & DINERO -->
      <Card variant="finance" class="text-left">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-4 bg-blue-100 text-blue-700 group-hover:scale-110 transition">
          <TrendingUp size={22} strokeWidth={1.8} />
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mb-3">
          Estrategia & Dinero
        </h3>

        <p class="text-gray-700 mb-4">
          Aprende a tomar decisiones inteligentes, entender el dinero y construir ingresos con enfoque a largo plazo.
        </p>

        <a href="/blog" class="text-sm font-medium text-blue-700 hover:underline">
          Explorar →
        </a>
      </Card>

      <!-- PENSAMIENTO CRÍTICO -->
      <Card variant="critical" class="text-left">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-4 bg-purple-100 text-purple-700 group-hover:scale-110 transition">
          <Brain size={22} strokeWidth={1.8} />
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mb-3">
          Pensamiento Crítico
        </h3>

        <p class="text-gray-700 mb-4">
          Desarrolla criterio propio y aprende a filtrar la información para no caer en falsas promesas ni distracciones.
        </p>

        <a href="/blog" class="text-sm font-medium text-purple-700 hover:underline">
          Leer análisis →
        </a>
      </Card>

      <!-- CREACIÓN & SISTEMAS -->
      <Card variant="author" class="text-left">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-4 bg-emerald-100 text-emerald-700 group-hover:scale-110 transition">
          <BookOpen size={22} strokeWidth={1.8} />
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mb-3">
          Creación & Sistemas
        </h3>

        <p class="text-gray-700 mb-4">
          Convierte ideas en contenido, proyectos y activos digitales que puedan crecer y generar valor con el tiempo.
        </p>

        <a href="/sobre-mi" class="text-sm font-medium text-emerald-700 hover:underline">
          Conocer más →
        </a>
      </Card>

    </div>
  </div>
</section>

  <!-- ARTÍCULOS -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-6xl mx-auto px-6">
      <FeaturedArticles
        title="Contenido estratégico"
        subtitle="Artículos clave para desarrollar criterio"
      />
    </div>
  </section>

  <!-- PRODUCTOS -->
<section class="mt-16 max-w-6xl mx-auto px-4">

  <div class="grid lg:grid-cols-3 gap-8 auto-rows-fr">

    <!-- 🟣 CARD GRANDE -->
    <div class="lg:col-span-2 p-8 rounded-3xl bg-gradient-to-br from-blue-600 to-indigo-700 text-white relative overflow-hidden h-full flex flex-col shadow-2xl hover:-translate-y-1 transition duration-300">

      <span class="text-xs bg-white/20 px-3 py-1 rounded-full w-fit mb-4">
        Más popular
      </span>

      <h3 class="text-2xl font-semibold">
        Deja de perder tiempo y empieza a generar ingresos online con un sistema probado
      </h3>

      <p class="mt-4 text-white/90 max-w-md flex-grow">
        Si no sabes por dónde empezar o ya intentaste sin resultados, aquí tienes un sistema claro paso a paso para construir ingresos digitales desde cero.
      </p>

      <a href="/productos/sistemas"
         class="mt-auto inline-block bg-white text-gray-900 px-6 py-3 rounded-xl font-semibold shadow-lg hover:shadow-xl transition">
        Quiero empezar desde cero →
      </a>

      <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-white/10 rounded-full blur-2xl"></div>
    </div>

    <!-- 🟢 COLUMNA DERECHA -->
    <div class="flex flex-col gap-8 h-full">

      <!-- CARD 1 -->
      <div class="p-6 rounded-2xl bg-white border border-gray-200 hover:shadow-2xl hover:-translate-y-1 transition duration-300 h-full flex flex-col">
        
        <h3 class="text-xl font-semibold text-gray-900">
          Aprende antes de ejecutar
        </h3>

        <p class="mt-3 text-gray-600 flex-grow">
          Si aún estás entendiendo cómo funciona esto, empieza con contenido claro y sin humo.
        </p>

        <a href="/productos/guias" class="mt-auto inline-block text-blue-600 font-medium">
          Empezar a aprender →
        </a>

      </div>

      <!-- CARD 2 -->
      <div class="p-6 rounded-2xl bg-white border border-gray-200 hover:shadow-2xl hover:-translate-y-1 transition duration-300 h-full flex flex-col">
        
        <h3 class="text-xl font-semibold text-gray-900">
          ¿Quieres ir más rápido?
        </h3>

        <p class="mt-3 text-gray-600 flex-grow">
          Trabajamos directamente en tu caso para evitar errores y avanzar con claridad.
        </p>

        <a href="/productos/consultoria" class="mt-auto inline-block text-blue-600 font-medium">
          Quiero ayuda personalizada →
        </a>

      </div>

    </div>

  </div>

</section>

  <!-- PODCAST -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-6xl mx-auto px-6">
      <FeaturedPodcast
        title="Reflexiones en audio"
        subtitle="Conversaciones profundas sobre estrategia y cultura"
        items={podcastEpisodes}
      />
    </div>
  </section>

  <!-- AUTOR -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-6">
      <AboutAuthor
        name="Gabnels"
        description="Construyo ideas que ayudan a pensar mejor, invertir mejor y crear proyectos digitales con estructura real."
        imageUrl="/images/authorGabnels.jpeg"
        link="/sobre-mi"
      />
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="bg-gray-900 py-16">
    <div class="max-w-3xl mx-auto px-6 text-center text-white">

      <h2 class="text-3xl font-bold mb-4">
        Newsletter estratégica (Premium)
      </h2>

      <p class="text-gray-300 mb-8">
        Análisis exclusivos y frameworks prácticos que no publico en abierto.
      </p>

      <a
        href="/newsletter"
        class="inline-flex items-center bg-white text-gray-900 font-medium px-6 py-3 rounded-lg hover:bg-gray-200 transition"
      >
        Suscribirme ahora
      </a>

    </div>
  </section>

</BaseLayout>